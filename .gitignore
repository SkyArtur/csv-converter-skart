# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Environments
.env
.envrc
.venv/
venv/
env/
ENV/

# PyCharm
.idea/

# My files
.pypirc
sandbox.py
guia.md

# Generated data files
*.csv
*.xlsx

# Exceções — fixtures de teste devem ser versionados
!csv_converter/tests/fixtures/
!csv_converter/tests/fixtures/input_files/
!csv_converter/tests/fixtures/input_files/*.xlsx
!csv_converter/tests/fixtures/input_files/*.csv
!csv_converter/tests/fixtures/expected_files/
!csv_converter/tests/fixtures/expected_files/*.csv

# Artefatos gerados pelos testes não são versionados
csv_converter/tests/artifacts/**/*.csv
csv_converter/tests/artifacts/**/*.xlsx
csv_converter/tests/artifacts/debug/**


